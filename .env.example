# Discord bot token (from discord.com/developers)
DISCORD_TOKEN=your_bot_token_here

# Your Discord user ID (right-click your name → Copy User ID)
ADMIN_DISCORD_ID=your_user_id_here

# Bot name (used for mention detection in groups)
BOT_NAME=brendbot

# Your bot's Discord user ID (right-click the bot → Copy User ID)
# Optional but recommended — helps with @mention detection
# DISCORD_BOT_ID=your_bot_user_id_here

# Claude model (sonnet = good balance, haiku = fast, opus = best)
CLAUDE_MODEL=sonnet

# Optional: comma-separated Discord user IDs for trusted tier
# TRUSTED_DISCORD_IDS=user_id_1,user_id_2

# Optional: Discord channel ID to receive operator alerts (classifier
# outages, session pool evictions). Leave unset to disable Discord alerts
# (they still land in logs/haiku_failures.log either way).
# ADMIN_ALERT_CHANNEL=your_alert_channel_id_here

# Google Cloud project + region for Imagen via Vertex AI (scripts/generate-image).
# Authentication is ADC — run `gcloud auth application-default login` once
# and these fields parameterise the project/region to call.
# GCP_PROJECT=your_gcp_project_id_here
# GCP_LOCATION=us-central1
# IMAGEN_MODEL=imagen-4.0-generate-001

# Session pool cap — how many persistent Claude subprocess sessions can be
# alive at once. Oldest idle session is evicted when the cap is reached.
# 0 disables the cap. Default is 20.
# MAX_SESSIONS=20
