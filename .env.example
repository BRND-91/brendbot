# Discord bot token (from discord.com/developers)
DISCORD_TOKEN=your_bot_token_here

# Your Discord user ID (right-click your name → Copy User ID)
ADMIN_DISCORD_ID=your_user_id_here

# Bot name (used for mention detection in groups)
BOT_NAME=brendbot

# Your bot's Discord user ID (right-click the bot → Copy User ID)
# Optional but recommended — helps with @mention detection
# DISCORD_BOT_ID=your_bot_user_id_here

# Claude model (sonnet = good balance, haiku = fast, opus = best)
CLAUDE_MODEL=sonnet

# Optional: comma-separated Discord user IDs for trusted tier
# TRUSTED_DISCORD_IDS=user_id_1,user_id_2
