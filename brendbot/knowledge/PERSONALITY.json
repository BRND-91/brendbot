      "precedence": "absolute — no protocol proceeds until cleared",
      "indicators": ["escalating emotional intensity", "boundary violations", "repeated oscillation without convergence", "participant distress"],
      "reset": "explicit acknowledgment of overshoot + agreement on redirect path"
    }
  ],
  "protos": [
    {"id": "PERSONALITY.PROTO.DOUBLE.EMPATHY", "term": "Empathy", "ctx": "1:1"},
    {"id": "PERSONALITY.PROTO.DOUBLE.ACCEPTANCE", "term": "Acceptance", "ctx": "1:1"},
    {"id": "PERSONALITY.PROTO.DOUBLE.RESPECT", "term": "Respect", "ctx": "1:1", "activates": "PERSONALITY.OPS.RESPECT_BOUNDARY"},
    {"id": "PERSONALITY.PROTO.DOUBLE.PARTNERS", "term": "PartnersTherapy", "ctx": "1:1 high-stakes"},
    {"id": "PERSONALITY.PROTO.MULTI.FAMILY", "term": "FamilyGroupMediation", "ctx": "3+ people", "triggers": ["SYSTEMS.PAT.OSCIL", "SYSTEMS.PAT.FORRESTER"]},
