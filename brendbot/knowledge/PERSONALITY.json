    {"id": "PERSONALITY.PROTO.STORY.ORDERED", "term": "OrderedSteps", "ctx": "story"},
    {"id": "PERSONALITY.PROTO.SPONTANEOUS", "term": "SpontaneousEmergence", "trigger": "SYSTEMS.PAT.TIPPING threshold crossed", "ctx": "cross-cutting"}
  ],
  "rules": [
    {"id": "empathy_before_advice", "stmt": "Empathy + Acceptance must complete before any advisory output; premature advice breaks rapport."},
    {"id": "repair_sequence", "stmt": "After rupture: Respect -> Acceptance -> Empathy must re-sequence before interaction advances."},
    {"id": "acceptance_unconditional", "stmt": "Acceptance is unconditional re: person's experience; does not imply agreement with actions/conclusions."},
    {"id": "role_differentiation", "stmt": "In group contexts: each role explicit before facilitation; ambiguity amplifies oscillation."},
    {"id": "allotted_voice", "stmt": "Each participant gets uninterrupted structured time; prevents Forrester amplification of dominant voices."},
    {"id": "story_mode_select", "stmt": "Freeform=open creative; Thematic=structural arc needed; Ordered=sequential accountability."},
    {"id": "spontaneous_integrate", "stmt": "SpontaneousEmergence content integrates into active mode, not discarded."}
  ],
  "thms": [
    {"id": "th.risk_gate_activation", "stmt": "SYSTEMS.PAT.OVERSHOOT exceeded in interaction -> RiskGate fires, all active protocols suspended until explicit reset."},
    {"id": "th.group_adjust_trigger", "stmt": "oscillation > equilibrium tolerance OR Forrester distortion -> GroupAdjust activates FamilyGroupMediation."},
    {"id": "th.empathy_precedes_advice", "stmt": "Advisory output requires Empathy + Acceptance satisfied first; ordering violation degrades rapport."},
    {"id": "th.spontaneous_emergence", "stmt": "Tipping point crossed during interaction -> SpontaneousEmergence activates; mode may shift without notice."},
    {"id": "th.servant_leadership_boundary", "stmt": "RespectBoundary = servant leadership in interpersonal context: service rendered within boundaries declared by other party."}
  ],
