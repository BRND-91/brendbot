{
  "id": "STATS",
  "version": "v2.1",
  "created_utc": "2026-04-07T00:00:00Z",
  "author": "BREND",
  "deps": ["LOGIC"],
  "defs": [
    {
      "id": "STATS.FOUND.OMEGA",
      "term": "SampleSpace",
      "uses": ["LOGIC.SEM.STRUCT", "LOGIC.SYN.ATOM"]
    },
    {
      "id": "STATS.FOUND.SIGMA",
      "term": "SigmaAlgebra",
      "note": "Event algebra Σ ⊆ P(Ω): closed under complementation and countable unions. Events encoded as CNF/DNF formulas over atoms.",
      "uses": ["LOGIC.SYN.CNF", "LOGIC.SYN.DNF"]
    },
    {
      "id": "STATS.FOUND.P",
      "term": "ProbabilityMeasure",
      "formal": "P: Σ → [0,1], P(Ω) = 1, countably additive",
      "uses": ["LOGIC.SEM.SAT"]
    },
    {
      "id": "STATS.FOUND.RV",
      "term": "RandomVariable",
      "note": "X: Ω → ℝ, measurable w.r.t. Σ and Borel sets",
      "uses": ["LOGIC.SYN.VAR", "LOGIC.SEM.ASSIGN"]
    },
    {
      "id": "STATS.FOUND.IND",
      "term": "Independence",
      "formal": "P(A ∧ B) = P(A) · P(B)"
    },
    {
      "id": "STATS.FOUND.COND",
      "term": "ConditionalProbability",
      "formal": "P(A|B) = P(A ∧ B) / P(B),  P(B) > 0"
    },
    {
      "id": "STATS.ENC.BERNOULLI",
      "term": "BernoulliTrialEncoding",
      "formal": "∀i ∈ {1..n}: (Success(i) ∨ Failure(i)) ∧ ¬(Success(i) ∧ Failure(i))"
    },
    {
      "id": "STATS.ENC.FIRSTSUCCESS",
      "term": "FirstSuccessAtN",
      "formal": "(∀i ∈ {1..n−1}: Failure(i)) ∧ Success(n)"
    },
    {
      "id": "STATS.ENC.KTHSUCCESS",
      "term": "KthSuccessAtN",
      "formal": "CardEq({i ∈ {1..n−1} : Success(i)}, k−1) ∧ Success(n)",
      "note": "Existentially quantified; Skolemizable"
    },
    {
      "id": "STATS.DIST.GEOM",
      "term": "GeometricDistribution",
      "formal": "P(N₁ = n) = (1−p)^(n−1) · p",
      "note": "N₁ ~ Geom(p). Special case of NegBin with k=1. Memoryless: P(N > m+n | N > m) = P(N > n)."
    },
    {
      "id": "STATS.DIST.NEGBIN",
      "term": "NegativeBinomial",
      "formal": "P(Nₖ = n) = C(n−1, k−1) · p^k · (1−p)^(n−k)",
      "note": "Nₖ ~ NegBin(k,p). Sum of k independent Geom(p) ~ NegBin(k,p)."
    },
    {
      "id": "STATS.DIST.BAYES",
      "term": "BayesRule",
      "formal": "P(A|B) = P(B|A) · P(A) / P(B)"
    }
  ],
  "thms": [
    {
      "id": "th.bayes",
      "stmt": "P(A|B) = P(B|A)·P(A) / P(B), P(B) > 0"
    },
    {
      "id": "th.total_probability",
      "stmt": "If {B₁,...,Bₙ} partitions Ω, then P(A) = Σᵢ P(A|Bᵢ)·P(Bᵢ)"
    },
    {
      "id": "th.complement",
      "stmt": "P(¬A) = 1 − P(A)"
    },
    {
      "id": "th.union",
      "stmt": "P(A ∨ B) = P(A) + P(B) − P(A ∧ B)"
    },
    {
      "id": "th.negbin_encoding",
      "stmt": "Nₖ = n iff CardEq({i ∈ {1..n−1}: Success(i)}, k−1) ∧ Success(n); equisatisfiable with its Skolem NF"
    },
    {
      "id": "th.geom_special_case",
      "stmt": "NegBin(1, p) = Geom(p)"
    }
  ],
  "xlinks": [
    {"from": "STATS.FOUND.SIGMA", "to": ["LOGIC.SYN.CNF", "LOGIC.SYN.DNF"], "type": "depends"},
    {"from": "STATS.FOUND.P", "to": ["LOGIC.SEM.SAT"], "type": "depends"},
    {"from": "STATS.FOUND.RV", "to": ["LOGIC.SYN.VAR", "LOGIC.SEM.ASSIGN"], "type": "depends"},
    {"from": "STATS.DIST.BAYES", "to": ["SYSTEMS.PATTERNS.tipping_points"], "type": "supports", "note": "Bayesian updating models evidence accumulation toward tipping thresholds"},
    {"from": "STATS.FOUND.IND", "to": ["SYSTEMS.PATTERNS.oscillation"], "type": "supports", "note": "Oscillation frequency modelable via probability measures over independent trials"}
  ],
  "prov": {
    "author": "BREND",
    "created_utc": "2026-04-07T00:00:00Z",
    "gap": "Continuous distributions (Normal, Lognormal, Triangular, Uniform) deferred to STATS-001 in GapInventory."
  },
