#!/usr/bin/env python3
"""
calc — evaluate a single-line arithmetic expression and echo it back.
Usage: calc "<expression>"
Example: calc "(52*(1/18) + 798*(1/60)) / 850"
"""

import sys
import math

SAFE_NS = {k: getattr(math, k) for k in dir(math) if not k.startswith('_')}
SAFE_NS['__builtins__'] = {}

def fmt(result: float) -> str:
    if abs(result) >= 100:
        return str(round(result))
    elif abs(result) >= 1:
        return f"{result:.2f}"
    else:
        return f"{result:.4f}"

def evaluate(expr: str) -> str:
    result = eval(expr, SAFE_NS)
    return f"{expr} = {fmt(result)}"

if __name__ == '__main__':
    if len(sys.argv) < 2:
        print("Usage: calc \"<expression>\"", file=sys.stderr)
        sys.exit(1)
    expr = sys.argv[1]
    try:
        print(evaluate(expr))
    except Exception as e:
        print(f"ERROR: {expr} -> {e}", file=sys.stderr)
        sys.exit(1)
