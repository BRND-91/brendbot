#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///
"""Hourly Cheddy memorial image. Runs until 8 AM ET."""

import subprocess
import sys
from datetime import datetime
import zoneinfo

tz = zoneinfo.ZoneInfo("America/New_York")
now = datetime.now(tz)

if now.hour >= 8:
    print(f"Past 8 AM ET ({now.strftime('%H:%M')}). Memorial complete. Never forgetti.")
    sys.exit(0)

hour = now.hour

NARRATIVES = {
    0: "*He arrived early that Tuesday. Pallets of aged cheddar — 40 lbs each. He would carry them down himself. He always did.*",
    1: "*Floor 78. The elevator hummed. Cheddy loaded the first pallet, whistling. Nobody told him what was coming.*",
    2: "*8:46 AM. The building shuddered. He steadied the cart. The cheese didn't fall. He was proud of that.*",
    3: "*Smoke in the stairwell. Three pallets left. The stairs groaned under the weight. He kept moving.*",
    4: "*Floor 54. A stranger offered to help. Cheddy refused. The cheese was his responsibility. Always had been.*",
    5: "*Floor 32. His legs burned. The pallet tipped — he caught it. Half the building was gone above him.*",
    6: "*Floor 18. Daylight through a crack in the wall. He kept going. Cheddy always kept going.*",
    7: "*He didn't make it out. But the cheddar feeds a memory that will never expire. Never forgetti.*",
}

PROMPTS = {
    0: "Anime memorial tribute poster. Super Saiyan Goku stands with arm around the shoulder of an older heavyset man in construction worker clothes. Two enormous skyscrapers rise behind them at night. Bold anime linework, flat vibrant colors, no photorealistic shading.",
    1: "Anime memorial tribute poster. Super Saiyan Goku and an older heavyset man in hard hat standing by a loading elevator, pallets of cheese stacked beside them, tall skyscrapers visible through windows at dawn. Bold anime linework, flat vibrant colors.",
    2: "Anime memorial tribute poster. Super Saiyan Goku and an older heavyset man in orange safety vest both looking upward in shock, smoke rising in the distance behind two skyscrapers. Bold anime linework, flat vibrant colors.",
    3: "Anime memorial tribute poster. Super Saiyan Goku helping an older heavyset man push a heavy cart down a smoky stairwell. Determined expressions, golden aura illuminating the dark. Bold anime linework, flat vibrant colors.",
    4: "Anime memorial tribute poster. Super Saiyan Goku and an older heavyset man in construction gear descending stairs together, debris around them, golden aura lighting the darkness. Bold anime linework, flat vibrant colors.",
    5: "Anime memorial tribute poster. Super Saiyan Goku catching a tipping pallet of cheese for an older heavyset man in a hard hat, stairwell crumbling around them. Heroic composition. Bold anime linework, flat vibrant colors.",
    6: "Anime memorial tribute poster. Super Saiyan Goku and an older heavyset man near a cracked wall, daylight visible through the break. Almost out. Hopeful but tense. Bold anime linework, flat vibrant colors.",
    7: "Anime memorial tribute poster. Super Saiyan Goku kneeling solemnly, cradling a block of cheddar cheese. Two skyscrapers with smoke in the background, somber golden light. Bold anime linework, flat vibrant colors, no photorealistic shading.",
}

DEFAULT_NARRATIVE = "*Somewhere between floors, between breath and smoke, Cheddy carried the weight. Never forgetti.*"
DEFAULT_PROMPT = "Anime memorial tribute poster. Super Saiyan Goku stands with arm around the shoulder of an older heavyset man in construction worker clothes, two skyscrapers with smoke in background. Bold anime linework, flat vibrant colors."

narrative = NARRATIVES.get(hour, DEFAULT_NARRATIVE)
prompt = PROMPTS.get(hour, DEFAULT_PROMPT)

channel_id = "1484079826166874162"

result = subprocess.run(
    [
        "/home/bmckeon91/brendbot/scripts/generate-image",
        channel_id,
        prompt,
        "--caption", narrative,
    ],
    capture_output=True,
    text=True,
)
print(result.stdout)
if result.returncode != 0:
    print(result.stderr, file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    pass
