#!/usr/bin/env python3
"""Export engagement classifier training data from audit logs.

Reads logs/bot_responses.jsonl (positive examples — messages the bot
engaged with) and logs/skip_decisions.jsonl (negative examples — messages
the engagement gate dropped) and emits one balanced JSONL stream with
(prompt, label) pairs suitable for fine-tuning a local classifier to
replace the haiku ambiguity gate.

Output schema (one row per example):
  - prompt: message text
  - label: "engage" or "skip"
  - score: heuristic engagement score (may be None on @-mention path)
  - address_level: high/moderate/low (engage rows only)
  - branch_tag: branch audit tag (engage rows only)
  - reason: skip-path tag (skip rows only)
  - channel_id / ts: provenance

Usage:
  scripts/export-training-data [--min-score N] [--output training.jsonl]
                               [--engage-only | --skip-only]
                               [--max-per-label N]
"""

from __future__ import annotations

import argparse
import json
import random
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).parent.parent
LOGS_DIR = PROJECT_ROOT / "logs"
BOT_RESPONSES = LOGS_DIR / "bot_responses.jsonl"
SKIP_DECISIONS = LOGS_DIR / "skip_decisions.jsonl"


def _iter_jsonl(path: Path):
    if not path.exists():
        return
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            yield json.loads(line)
        except json.JSONDecodeError:
            continue


def _engage_rows(min_score: float | None):
    for row in _iter_jsonl(BOT_RESPONSES):
        score = row.get("score")
        if min_score is not None and score is not None and score < min_score:
            continue
        prompt = row.get("user_text", "")
        if not prompt:
            continue
        yield {
            "prompt": prompt,
            "label": "engage",
            "score": score,
            "address_level": row.get("address_level", ""),
            "branch_tag": row.get("branch_tag"),
            "reason": None,
            "channel_id": row.get("channel_id", ""),
            "ts": row.get("ts", ""),
        }


def _skip_rows(min_score: float | None):
    for row in _iter_jsonl(SKIP_DECISIONS):
        score = row.get("score")
        if min_score is not None and score is not None and score < min_score:
            continue
        prompt = row.get("user_text", "")
        if not prompt:
            continue
        yield {
            "prompt": prompt,
            "label": "skip",
            "score": score,
            "address_level": None,
            "branch_tag": None,
            "reason": row.get("reason", ""),
            "channel_id": row.get("channel_id", ""),
            "ts": row.get("ts", ""),
        }


def export(
    output_path: str,
    min_score: float | None,
    engage_only: bool,
    skip_only: bool,
    max_per_label: int | None,
) -> None:
    engage = [] if skip_only else list(_engage_rows(min_score))
    skip = [] if engage_only else list(_skip_rows(min_score))

    if max_per_label is not None:
        if len(engage) > max_per_label:
            random.shuffle(engage)
            engage = engage[:max_per_label]
        if len(skip) > max_per_label:
            random.shuffle(skip)
            skip = skip[:max_per_label]

    combined = engage + skip
    random.shuffle(combined)

    with open(output_path, "w") as out:
        for rec in combined:
            out.write(json.dumps(rec, ensure_ascii=False) + "\n")

    print(
        f"Exported {len(combined)} rows to {output_path} "
        f"(engage={len(engage)}, skip={len(skip)})"
    )
    if not engage:
        print(f"  note: no engage examples (looked at {BOT_RESPONSES}).", file=sys.stderr)
    if not skip:
        print(f"  note: no skip examples (looked at {SKIP_DECISIONS}).", file=sys.stderr)


def main() -> None:
    parser = argparse.ArgumentParser(description="Export engagement classifier training data")
    parser.add_argument("--output", "-o", default="training.jsonl")
    parser.add_argument("--min-score", type=float, default=None)
    parser.add_argument("--engage-only", action="store_true")
    parser.add_argument("--skip-only", action="store_true")
    parser.add_argument("--max-per-label", type=int, default=None)
    args = parser.parse_args()
    if args.engage_only and args.skip_only:
        parser.error("--engage-only and --skip-only are mutually exclusive")
    export(
        output_path=args.output,
        min_score=args.min_score,
        engage_only=args.engage_only,
        skip_only=args.skip_only,
        max_per_label=args.max_per_label,
    )


if __name__ == "__main__":
    main()
