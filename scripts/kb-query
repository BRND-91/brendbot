#!/usr/bin/env python3
"""Query the FUSED-CORE knowledge base (SQLite).

Modules present: BUILDSCI, IMAGEGEN.

Usage:
    kb-query search <terms>          Full-text search across all modules
    kb-query defs <MODULE>           List all definitions in a module
    kb-query facts <MODULE> [topic]  List facts (optionally filtered by topic)
    kb-query thms <MODULE>           List core theorems in a module
    kb-query thms <MODULE> --extended List all theorems including extended (geometry, etc.)
    kb-query def <ID>                Look up a specific definition by ID
    kb-query xlinks <MODULE>         List crosslinks for a module
    kb-query topics <MODULE>         List available fact topics in a module
    kb-query imagegen <section>      Get IMAGEGEN config section (use 'all' for all, 'sections' to list)
    kb-query memory <source> [tag]   Get memory fragment entries by source file (e.g., bots, tools)
    kb-query memory search <terms>   Search memory fragment content

    Image generation prompt construction:
    kb-query imgstyle <id|label>     Get descriptor set for a named style (e.g. 'junji_ito', 'manga')
    kb-query imgstyle list           List all available styles
    kb-query imgfail <failure_class> Get remediation for a known failure pattern
    kb-query imgfail list            List all known failure classes
    kb-query imglog <request_hash>   Get prior render attempt history for a request hash
    kb-query imglog recent [N]       Get N most recent render outcomes (default 10)

Examples:
    kb-query search "R-value"
    kb-query search "insul*"           (prefix matching)
    kb-query defs BUILDSCI
    kb-query facts BUILDSCI airflow
    kb-query def BSCI.ENCL.RVALUE
    kb-query imgstyle junji_ito
    kb-query imgstyle list
    kb-query imgfail style_not_transferred
    kb-query imgfail list
    kb-query imglog recent 5

    Energy model — building envelope (residential 1-4 family, MA-focused):
    kb-query envelope <type>          Walls/roofs/floors/foundations: list assemblies of given type
    kb-query envelope <type> <filter> Filter by framing or material substring (e.g. "wall 2x6")
    kb-query envelope id <ASMID>      Lookup full assembly with layer breakdown by ID
    kb-query fenestration             List all window/door/skylight entries
    kb-query fenestration <filter>    Filter (e.g. "vinyl triple", "wood double argon", "door fiberglass")
    kb-query ci                       List continuous insulation products with R/in
    kb-query ci <material>            Lookup specific CI material entry
    kb-query macode <CZ> [edition]    MA code minima for climate zone (default CZ5); editions:
                                      BBRS10|IECC2021|MA_STRETCH|MA_SPECIALIZED|all (default all)
    kb-query mawx [town|station]      MA weather station data (HDD/CDD/design temps).
                                      No arg = list all 11 stations; arg = town name or station code.

    Examples (envelope):
    kb-query envelope wall 2x6
    kb-query envelope id ENV.WALL.2x6_16OC_R21FG_VNYL
    kb-query fenestration "triple low-e argon"
    kb-query ci polyiso
    kb-query macode 5 MA_SPECIALIZED
    kb-query mawx Boston
"""

import sqlite3
import sys
from pathlib import Path

DB_PATH = Path(__file__).resolve().parent.parent / "brendbot" / "knowledge" / "knowledge.db"


def get_conn():
    if not DB_PATH.exists():
        print(f"Error: {DB_PATH} not found. Run migrate_to_sqlite.py first.", file=sys.stderr)
        sys.exit(1)
    return sqlite3.connect(str(DB_PATH))


def _check_module_coverage(conn, terms):
    modules = conn.execute("SELECT id, description FROM modules").fetchall()
    terms_lower = terms.lower()
    for mod_id, desc in modules:
        if mod_id.lower() in terms_lower or (desc and any(w in terms_lower for w in desc.lower().split() if len(w) > 4)):
            return mod_id
    return None


def cmd_search(terms):
    conn = get_conn()
    fts_terms = '"' + terms.replace('"', '""') + '"'
    results = conn.execute(
        "SELECT module_id, entry_type, term, description, source "
        "FROM fts_knowledge WHERE fts_knowledge MATCH ? LIMIT 20",
        (fts_terms,)
    ).fetchall()

    if not results:
        like = f"%{terms}%"
        results = conn.execute(
            "SELECT module_id, 'def' as entry_type, term, description, source "
            "FROM definitions WHERE term LIKE ? OR description LIKE ? OR formal LIKE ? "
            "UNION ALL "
            "SELECT module_id, 'fact', name, description, source "
            "FROM facts WHERE name LIKE ? OR description LIKE ? "
            "LIMIT 20",
            (like, like, like, like, like)
        ).fetchall()

    if not results:
        matched_module = _check_module_coverage(conn, terms)
        if matched_module:
            print(f"[NO_MODULE_MATCH] Module {matched_module} covers this domain but returned no results.")
        else:
            print("No results.")
        return

    for mod, etype, term, desc, src in results:
        src_tag = f"|{src}" if src else ""
        print(f"{mod}.{etype}:{term}={desc}{src_tag}")


def cmd_defs(module):
    conn = get_conn()
    rows = conn.execute(
        "SELECT id, term, description, formal, source FROM definitions WHERE module_id=? ORDER BY id",
        (module.upper(),)
    ).fetchall()
    if not rows:
        print(f"No defs for {module}")
        return
    for did, term, desc, formal, src in rows:
        line = f"{did}:{term}={desc}" if desc else f"{did}:{term}"
        if formal:
            line += f"|F:{formal}"
        if src:
            line += f"|{src}"
        print(line)


def cmd_facts(module, topic=None):
    conn = get_conn()
    if topic:
        rows = conn.execute(
            "SELECT topic, name, description, source FROM facts WHERE module_id=? AND topic=? ORDER BY name",
            (module.upper(), topic)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT topic, name, description, source FROM facts WHERE module_id=? ORDER BY topic, name",
            (module.upper(),)
        ).fetchall()
    if not rows:
        print(f"No facts for {module}" + (f"/{topic}" if topic else ""))
        return
    for t, name, desc, src in rows:
        src_tag = f"|{src}" if src else ""
        print(f"{t}.{name}={desc}{src_tag}")


def cmd_thms(module, include_extended=False):
    conn = get_conn()
    if include_extended:
        rows = conn.execute(
            "SELECT id, description, formal, source, extended FROM theorems WHERE module_id=? ORDER BY extended, id",
            (module.upper(),)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT id, description, formal, source, extended FROM theorems WHERE module_id=? AND extended=0 ORDER BY id",
            (module.upper(),)
        ).fetchall()
    if not rows:
        ext_count = conn.execute(
            "SELECT COUNT(*) FROM theorems WHERE module_id=? AND extended=1",
            (module.upper(),)
        ).fetchone()[0]
        if ext_count and not include_extended:
            print(f"No core thms for {module}. {ext_count} extended theorems available (use --extended).")
        else:
            print(f"No thms for {module}")
        return
    for tid, desc, formal, src, ext in rows:
        line = f"{tid}={desc}" if desc else f"{tid}"
        if formal:
            line += f"|F:{formal}"
        if src:
            line += f"|{src}"
        if ext:
            line += " [EXTENDED]"
        print(line)


def cmd_def_lookup(def_id):
    conn = get_conn()
    row = conn.execute(
        "SELECT id, module_id, term, description, formal, source FROM definitions WHERE id=?",
        (def_id,)
    ).fetchone()
    if not row:
        print(f"Definition '{def_id}' not found")
        return
    did, mod, term, desc, formal, src = row
    print(f"Module: {mod}")
    print(f"Term: {term}")
    if desc: print(f"Description: {desc}")
    if formal: print(f"Formal: {formal}")
    if src: print(f"Source: {src}")


def cmd_xlinks(module):
    conn = get_conn()
    rows = conn.execute(
        "SELECT from_id, to_ids, link_type, note FROM crosslinks WHERE module_id=? ORDER BY from_id",
        (module.upper(),)
    ).fetchall()
    if not rows:
        print(f"No crosslinks found for {module}")
        return
    for fr, to, lt, note in rows:
        print(f"{fr} --[{lt}]--> {to}: {note}")


def cmd_imagegen(section):
    conn = get_conn()
    if section == "sections":
        rows = conn.execute("SELECT section FROM imagegen_config ORDER BY section").fetchall()
        if not rows:
            print("No imagegen_config sections found. Run migrate_to_sqlite.py first.")
            return
        for (s,) in rows:
            print(s)
        return
    if section == "all":
        rows = conn.execute("SELECT section, data FROM imagegen_config ORDER BY section").fetchall()
        if not rows:
            print("No imagegen_config data found. Run migrate_to_sqlite.py first.")
            return
        import json
        for s, d in rows:
            print(f"=== {s} ===")
            print(d)
        return
    row = conn.execute("SELECT data FROM imagegen_config WHERE section=?", (section,)).fetchone()
    if not row:
        print(f"Section '{section}' not found. Use 'kb-query imagegen sections' to list available sections.")
        return
    print(row[0])


def cmd_imgstyle(arg):
    """Look up descriptor set for a named style, or list all styles."""
    conn = get_conn()

    if arg == "list":
        rows = conn.execute(
            "SELECT id, label, model_tier, notes FROM prompt_styles ORDER BY id"
        ).fetchall()
        if not rows:
            print("No prompt_styles found. Run migrate_to_sqlite.py first.")
            return
        for sid, label, tier, notes in rows:
            note_str = f" | {notes}" if notes else ""
            print(f"{sid}: {label} [{tier}]{note_str}")
        return

    # Try exact id match first, then FTS label search
    row = conn.execute(
        "SELECT id, label, core_descriptors, supplemental_descriptors, negative_space, fail_modes, model_tier, notes "
        "FROM prompt_styles WHERE id=?",
        (arg.lower(),)
    ).fetchone()

    if not row:
        # FTS search on label and descriptors
        fts_term = '"' + arg.replace('"', '""') + '"'
        try:
            fts_rows = conn.execute(
                "SELECT id FROM fts_prompts WHERE fts_prompts MATCH ? LIMIT 3",
                (fts_term,)
            ).fetchall()
        except Exception:
            fts_rows = []
        if fts_rows:
            matched_id = fts_rows[0][0]
            row = conn.execute(
                "SELECT id, label, core_descriptors, supplemental_descriptors, negative_space, fail_modes, model_tier, notes "
                "FROM prompt_styles WHERE id=?",
                (matched_id,)
            ).fetchone()

    if not row:
        print(f"Style '{arg}' not found. Use 'kb-query imgstyle list' to see available styles.")
        return

    sid, label, core, supplemental, negative, fail_modes_json, tier, notes = row
    print(f"id: {sid}")
    print(f"label: {label}")
    print(f"tier: {tier}")
    print(f"core: {core}")
    if supplemental:
        print(f"supplemental: {supplemental}")
    if negative:
        print(f"avoid: {negative}")
    if notes:
        print(f"notes: {notes}")


def cmd_imgstyle_assemble(visual_id, tonal_id):
    """Assemble a flat prompt descriptor from visual base + tonal base + optional delta.

    Priority for negative_space conflicts: delta > tonal > visual.
    Returns assembled fields in the same format as cmd_imgstyle.
    """
    conn = get_conn()

    def fetch_style(sid):
        return conn.execute(
            "SELECT id, label, core_descriptors, supplemental_descriptors, negative_space, model_tier, notes "
            "FROM prompt_styles WHERE id=?",
            (sid.lower(),)
        ).fetchone()

    visual = fetch_style(visual_id)
    tonal = fetch_style(tonal_id)

    if not visual:
        print(f"Visual style '{visual_id}' not found.")
        return
    if not tonal:
        print(f"Tonal style '{tonal_id}' not found.")
        return

    # Check for a delta row
    delta_id = f"{visual_id.lower()}:{tonal_id.lower()}"
    delta = fetch_style(delta_id)

    def split_terms(text):
        return [t.strip() for t in (text or "").split(",") if t.strip()]

    def merge_avoid(vis_avoid, ton_avoid, delta_avoid):
        """Union base avoids, then delta overrides: removes contradictions, adds its own."""
        base = split_terms(vis_avoid) + split_terms(ton_avoid)
        if not delta_avoid:
            return ", ".join(dict.fromkeys(base))  # dedup, preserve order
        delta_terms = split_terms(delta_avoid)
        # Delta is authoritative: start from delta, add non-conflicting base terms
        delta_lower = {t.lower() for t in delta_terms}
        filtered_base = [t for t in base if t.lower() not in delta_lower]
        merged = delta_terms + filtered_base
        return ", ".join(dict.fromkeys(merged))

    # Merge cores: visual first, tonal second, delta additions appended
    core_parts = split_terms(visual[2]) + split_terms(tonal[2])
    if delta:
        core_parts += split_terms(delta[2])
    core = ", ".join(dict.fromkeys(core_parts))

    # Merge supplemental
    sup_parts = split_terms(visual[3]) + split_terms(tonal[3])
    if delta:
        sup_parts += split_terms(delta[3])
    supplemental = ", ".join(dict.fromkeys(sup_parts))

    # Merge avoid with priority: delta > tonal > visual
    avoid = merge_avoid(visual[4], tonal[4], delta[4] if delta else None)

    # Tier: take the highest (ultra > standard > fast)
    tier_rank = {"fast": 0, "standard": 1, "ultra": 2, "ultra final / standard iteration": 2}
    tiers = [visual[5], tonal[5]]
    if delta:
        tiers.append(delta[5])
    tier = max((t for t in tiers if t), key=lambda t: tier_rank.get(t, 1), default="standard")

    # Notes: delta note takes precedence if present
    notes = (delta[6] if delta and delta[6] else None) or tonal[6] or visual[6]

    label = f"{visual[1]} x {tonal[1]}"
    assembled_id = delta_id if delta else f"{visual_id}+{tonal_id} (untested)"

    print(f"id: {assembled_id}")
    print(f"label: {label}")
    print(f"tier: {tier}")
    print(f"core: {core}")
    if supplemental:
        print(f"supplemental: {supplemental}")
    if avoid:
        print(f"avoid: {avoid}")
    if notes:
        print(f"notes: {notes}")
    if not delta:
        print("warning: no interaction delta found — composition is untested, may need a pass")


def cmd_imgfail(arg):
    """Look up remediation for a known failure class, or list all classes."""
    conn = get_conn()

    if arg == "list":
        rows = conn.execute(
            "SELECT failure_class, trigger_pattern FROM render_failures ORDER BY failure_class"
        ).fetchall()
        if not rows:
            print("No render_failures found. Run migrate_to_sqlite.py first.")
            return
        for fc, trigger in rows:
            print(f"{fc}: {trigger}")
        return

    row = conn.execute(
        "SELECT failure_class, trigger_pattern, remediation, example "
        "FROM render_failures WHERE failure_class=?",
        (arg,)
    ).fetchone()
    if not row:
        # Try LIKE match
        like = f"%{arg}%"
        rows = conn.execute(
            "SELECT failure_class, trigger_pattern, remediation, example "
            "FROM render_failures WHERE failure_class LIKE ? OR trigger_pattern LIKE ?",
            (like, like)
        ).fetchall()
        if not rows:
            print(f"Failure class '{arg}' not found. Use 'kb-query imgfail list' to see all classes.")
            return
        row = rows[0]

    fc, trigger, remediation, example = row
    print(f"class: {fc}")
    print(f"trigger: {trigger}")
    print(f"remediation: {remediation}")
    if example:
        print(f"example: {example}")


def cmd_imglog(args):
    """Query render outcome history."""
    conn = get_conn()

    if not args:
        print("Usage: kb-query imglog <request_hash> | kb-query imglog recent [N]")
        return

    if args[0] == "recent":
        n = int(args[1]) if len(args) >= 2 else 10
        rows = conn.execute(
            "SELECT request_hash, attempt_number, constraint_score, succeeded, failure_class, notes, created_at "
            "FROM render_outcomes ORDER BY created_at DESC LIMIT ?",
            (n,)
        ).fetchall()
        if not rows:
            print("No render outcomes logged yet.")
            return
        for req_hash, attempt, score, succeeded, fc, notes, ts in rows:
            status = "OK" if succeeded else f"FAIL:{fc or '?'}"
            hash_short = (req_hash or "?")[:12]
            note_str = f" | {notes}" if notes else ""
            print(f"{ts} [{hash_short}] attempt={attempt} constraints={score} {status}{note_str}")
        return

    # Lookup by request hash
    request_hash = args[0]
    rows = conn.execute(
        "SELECT attempt_number, prompt_used, style_ids, constraint_score, succeeded, failure_class, notes, created_at "
        "FROM render_outcomes WHERE request_hash=? ORDER BY attempt_number",
        (request_hash,)
    ).fetchall()
    if not rows:
        print(f"No outcomes found for hash '{request_hash}'.")
        return
    for attempt, prompt, style_ids, score, succeeded, fc, notes, ts in rows:
        status = "OK" if succeeded else f"FAIL:{fc or '?'}"
        print(f"attempt {attempt} [{ts}]: {status} | constraints={score} | styles={style_ids or 'none'}")
        if prompt:
            print(f"  prompt: {prompt[:200]}")
        if notes:
            print(f"  notes: {notes}")


def cmd_memory(args):
    conn = get_conn()
    if args and args[0] == "search":
        terms = " ".join(args[1:])
        like = f"%{terms}%"
        rows = conn.execute(
            "SELECT source, tag, content FROM memory_fragments "
            "WHERE content LIKE ? OR tag LIKE ? ORDER BY source, id",
            (like, like),
        ).fetchall()
        if not rows:
            print("No memory fragment entries matched.")
            return
        for source, tag, content in rows:
            print(f"[{source}/{tag}] {content}")
        return

    if not args:
        rows = conn.execute(
            "SELECT DISTINCT source, COUNT(*) FROM memory_fragments GROUP BY source ORDER BY source"
        ).fetchall()
        if not rows:
            print("memory_fragments table is empty. Run migrate_to_sqlite.py first.")
            return
        for source, count in rows:
            print(f"  {source} ({count} entries)")
        return

    source = args[0]
    tag = args[1] if len(args) >= 2 else None

    if tag:
        rows = conn.execute(
            "SELECT tag, content FROM memory_fragments WHERE source=? AND tag=? ORDER BY id",
            (source, tag),
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT tag, content FROM memory_fragments WHERE source=? ORDER BY id",
            (source,),
        ).fetchall()

    if not rows:
        available = [
            r[0]
            for r in conn.execute(
                "SELECT DISTINCT source FROM memory_fragments ORDER BY source"
            ).fetchall()
        ]
        msg = f"No entries found for source='{source}'"
        if tag:
            msg += f" tag='{tag}'"
        print(msg)
        if available:
            print(f"Available sources: {', '.join(available)}")
        return

    for t, content in rows:
        print(f"[{t}] {content}")


def cmd_topics(module):
    conn = get_conn()
    rows = conn.execute(
        "SELECT DISTINCT topic, COUNT(*) FROM facts WHERE module_id=? GROUP BY topic ORDER BY topic",
        (module.upper(),)
    ).fetchall()
    if not rows:
        print(f"No topics found for {module}")
        return
    for topic, count in rows:
        print(f"  {topic} ({count} facts)")


# ─── ENVELOPE / ENERGY MODEL QUERIES ─────────────────────────────────────────

def _src_tag(src):
    return f"|{src}" if src else ""


def cmd_envelope(args):
    """List/filter envelope assemblies, or look up by id."""
    if not args:
        print("Usage: kb-query envelope <type> [filter] | kb-query envelope id <ASMID>")
        return
    conn = get_conn()

    if args[0] == "id":
        if len(args) < 2:
            print("Usage: kb-query envelope id <ASMID>")
            return
        aid = args[1]
        row = conn.execute(
            "SELECT assembly_id, type, name, description, framing, spacing_in, "
            "       cavity_material, cavity_r_nominal, ci_material, ci_r, "
            "       sheathing_material, sheathing_r, exterior_finish, interior_finish, "
            "       framing_factor, r_clear_path, r_framing_path, r_effective, u_effective, "
            "       calc_method, source_id, source_section, "
            "       ma_compliant_base, ma_compliant_stretch, ma_compliant_specialized, note "
            "FROM envelope_assemblies WHERE assembly_id = ?", (aid,)
        ).fetchone()
        if not row:
            print(f"Assembly '{aid}' not found.")
            return
        keys = [
            "assembly_id","type","name","description","framing","spacing_in",
            "cavity_material","cavity_r_nominal","ci_material","ci_r",
            "sheathing_material","sheathing_r","exterior_finish","interior_finish",
            "framing_factor","r_clear_path","r_framing_path","r_effective","u_effective",
            "calc_method","source_id","source_section",
            "ma_compliant_base","ma_compliant_stretch","ma_compliant_specialized","note",
        ]
        for k, v in zip(keys, row):
            if v not in (None, ""):
                print(f"{k}: {v}")
        # Layers
        layers = conn.execute(
            "SELECT layer_order, layer_role, material, thickness_in, r_per_in, r_layer, note "
            "FROM envelope_layers WHERE assembly_id = ? ORDER BY layer_order", (aid,)
        ).fetchall()
        if layers:
            print("\n--- Layers (interior to exterior) ---")
            for ord_, role, mat, thk, rpi, rl, note in layers:
                thk_s = f" {thk}\"" if thk else ""
                rpi_s = f" R/in={rpi}" if rpi else ""
                rl_s = f" R={rl}" if rl else ""
                note_s = f" — {note}" if note else ""
                print(f"  {ord_}. [{role}] {mat}{thk_s}{rpi_s}{rl_s}{note_s}")
        return

    asm_type = args[0]
    filter_term = " ".join(args[1:]) if len(args) >= 2 else None

    if filter_term:
        like = f"%{filter_term}%"
        rows = conn.execute(
            "SELECT assembly_id, name, framing, spacing_in, cavity_r_nominal, ci_r, "
            "       r_effective, u_effective, source_id "
            "FROM envelope_assemblies "
            "WHERE type = ? AND ("
            "      framing LIKE ? OR name LIKE ? OR description LIKE ? OR "
            "      cavity_material LIKE ? OR exterior_finish LIKE ? OR ci_material LIKE ?)"
            "ORDER BY r_effective DESC",
            (asm_type, like, like, like, like, like, like)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT assembly_id, name, framing, spacing_in, cavity_r_nominal, ci_r, "
            "       r_effective, u_effective, source_id "
            "FROM envelope_assemblies WHERE type = ? ORDER BY r_effective DESC",
            (asm_type,)
        ).fetchall()

    if not rows:
        print(f"No assemblies found for type='{asm_type}'" + (f" filter='{filter_term}'" if filter_term else ""))
        return
    print(f"{'ID':<40} {'Framing':<8} {'OC':<3} {'CavR':>5} {'CIR':>5} {'Reff':>6} {'Ueff':>7}  Source")
    for aid, name, fr, sp, cav, ci, reff, ueff, src in rows:
        print(f"{aid:<40} {fr or '-':<8} {sp or '-':<3} {cav or 0:>5} {ci or 0:>5} {reff or 0:>6.1f} {ueff or 0:>7.4f}  {src or ''}")


def cmd_fenestration(args):
    conn = get_conn()
    filter_term = " ".join(args) if args else None
    if filter_term:
        like = f"%{filter_term}%"
        rows = conn.execute(
            "SELECT fen_id, type, name, frame_material, glazing_layers, low_e, gas_fill, "
            "       u_factor, shgc, vt, source_id "
            "FROM fenestration_assemblies "
            "WHERE name LIKE ? OR description LIKE ? OR frame_material LIKE ? OR "
            "      low_e LIKE ? OR gas_fill LIKE ? OR type LIKE ? "
            "ORDER BY u_factor",
            (like, like, like, like, like, like)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT fen_id, type, name, frame_material, glazing_layers, low_e, gas_fill, "
            "       u_factor, shgc, vt, source_id "
            "FROM fenestration_assemblies ORDER BY type, u_factor"
        ).fetchall()
    if not rows:
        print("No fenestration entries found.")
        return
    print(f"{'ID':<32} {'Type':<8} {'Frame':<10} {'L':<2} {'LowE':<10} {'Gas':<6} {'U':>5} {'SHGC':>5} {'VT':>5}  Source")
    for fid, t, name, fr, ly, le, gas, u, shgc, vt, src in rows:
        print(f"{fid:<32} {t or '-':<8} {fr or '-':<10} {ly or '-':<2} {le or '-':<10} {gas or '-':<6} "
              f"{u or 0:>5.2f} {shgc or 0:>5.2f} {vt or 0:>5.2f}  {src or ''}")


def cmd_ci(args):
    conn = get_conn()
    if not args:
        rows = conn.execute(
            "SELECT ci_id, name, material, r_per_in_nominal, r_per_in_aged, source_id "
            "FROM ci_materials ORDER BY r_per_in_aged DESC, name"
        ).fetchall()
        if not rows:
            print("No CI materials.")
            return
        print(f"{'ID':<28} {'Material':<14} {'R/in nom':>9} {'R/in aged':>10}  Source")
        for cid, name, mat, rn, ra, src in rows:
            print(f"{cid:<28} {mat or '-':<14} {rn or 0:>9.2f} {ra or 0:>10.2f}  {src or ''}")
        return
    arg = " ".join(args)
    like = f"%{arg}%"
    rows = conn.execute(
        "SELECT ci_id, name, material, r_per_in_nominal, r_per_in_aged, density_pcf, "
        "       vapor_perm, water_absorb_pct, flame_spread, smoke_developed, typical_use, "
        "       source_id, source_section, note "
        "FROM ci_materials WHERE ci_id LIKE ? OR name LIKE ? OR material LIKE ? OR typical_use LIKE ?",
        (like, like, like, like)
    ).fetchall()
    if not rows:
        print(f"No CI material matched '{arg}'.")
        return
    for r in rows:
        keys = ["ci_id","name","material","r_per_in_nominal","r_per_in_aged","density_pcf",
                "vapor_perm","water_absorb_pct","flame_spread","smoke_developed","typical_use",
                "source_id","source_section","note"]
        for k, v in zip(keys, r):
            if v not in (None, ""):
                print(f"{k}: {v}")
        print("-" * 40)


def cmd_macode(args):
    conn = get_conn()
    cz = args[0] if args else "5"
    edition = args[1] if len(args) >= 2 else "all"
    if edition.lower() == "all":
        rows = conn.execute(
            "SELECT code_edition, code_section, climate_zone, component, metric, value, unit, depth_in, source_id "
            "FROM ma_code_minimums WHERE climate_zone LIKE ? "
            "ORDER BY component, code_edition", (f"%{cz}%",)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT code_edition, code_section, climate_zone, component, metric, value, unit, depth_in, source_id "
            "FROM ma_code_minimums WHERE climate_zone LIKE ? AND code_edition = ? "
            "ORDER BY component, code_edition", (f"%{cz}%", edition)
        ).fetchall()
    if not rows:
        print(f"No code minima found for CZ={cz} edition={edition}")
        return
    print(f"{'Edition':<18} {'Section':<14} {'CZ':<4} {'Component':<22} {'Metric':<8} {'Value':>7} {'Unit':<5} {'Depth':>5}  Source")
    for ed, sec, z, comp, met, val, un, d, src in rows:
        d_s = str(d) if d is not None else "-"
        print(f"{ed:<18} {sec or '-':<14} {z:<4} {comp:<22} {met:<8} {val:>7.2f} {un or '-':<5} {d_s:>5}  {src or ''}")


def cmd_mawx(args):
    conn = get_conn()
    if not args:
        rows = conn.execute(
            "SELECT station_code, label, climate_zone, hdd65, cdd65, design_temp_heating, design_temp_cooling "
            "FROM ma_climate_stations ORDER BY station_code"
        ).fetchall()
        if not rows:
            print("No MA climate stations found.")
            return
        print(f"{'Code':<5} {'Label':<32} {'CZ':<3} {'HDD65':>6} {'CDD65':>6} {'99% W':>6} {'1% S':>6}")
        for c, lbl, z, hdd, cdd, h, cl in rows:
            print(f"{c:<5} {lbl:<32} {z:<3} {hdd or 0:>6} {cdd or 0:>6} {h or 0:>6.0f} {cl or 0:>6.0f}")
        return
    q = " ".join(args)
    like = f"%{q}%"
    rows = conn.execute(
        "SELECT station_code, label, climate_zone, hdd65, cdd65, design_temp_heating, "
        "       design_temp_cooling, covers, source_id, note "
        "FROM ma_climate_stations "
        "WHERE station_code LIKE ? OR label LIKE ? OR covers LIKE ?",
        (like, like, like)
    ).fetchall()
    if not rows:
        print(f"No MA station/town matching '{q}'.")
        return
    for c, lbl, z, hdd, cdd, h, cl, cov, src, note in rows:
        print(f"station_code: {c}")
        print(f"label: {lbl}")
        print(f"climate_zone: {z}")
        print(f"hdd65: {hdd}")
        print(f"cdd65: {cdd}")
        print(f"design_temp_heating (99%): {h}")
        print(f"design_temp_cooling (1%): {cl}")
        if cov:
            print(f"covers: {cov}")
        if src:
            print(f"source: {src}")
        if note:
            print(f"note: {note}")
        print("-" * 40)



def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "search" and len(sys.argv) >= 3:
        cmd_search(" ".join(sys.argv[2:]))
    elif cmd == "defs" and len(sys.argv) >= 3:
        cmd_defs(sys.argv[2])
    elif cmd == "facts" and len(sys.argv) >= 3:
        topic = sys.argv[3] if len(sys.argv) >= 4 else None
        cmd_facts(sys.argv[2], topic)
    elif cmd == "thms" and len(sys.argv) >= 3:
        extended = "--extended" in sys.argv
        cmd_thms(sys.argv[2], include_extended=extended)
    elif cmd == "def" and len(sys.argv) >= 3:
        cmd_def_lookup(sys.argv[2])
    elif cmd == "xlinks" and len(sys.argv) >= 3:
        cmd_xlinks(sys.argv[2])
    elif cmd == "topics" and len(sys.argv) >= 3:
        cmd_topics(sys.argv[2])
    elif cmd == "imagegen" and len(sys.argv) >= 3:
        cmd_imagegen(sys.argv[2])
    elif cmd == "imgstyle" and len(sys.argv) >= 3:
        cmd_imgstyle(sys.argv[2])
    elif cmd == "imgstyle_assemble" and len(sys.argv) >= 4:
        cmd_imgstyle_assemble(sys.argv[2], sys.argv[3])
    elif cmd == "imgfail" and len(sys.argv) >= 3:
        cmd_imgfail(sys.argv[2])
    elif cmd == "imglog":
        cmd_imglog(sys.argv[2:])
    elif cmd == "memory":
        cmd_memory(sys.argv[2:])
    elif cmd == "envelope":
        cmd_envelope(sys.argv[2:])
    elif cmd == "fenestration":
        cmd_fenestration(sys.argv[2:])
    elif cmd == "ci":
        cmd_ci(sys.argv[2:])
    elif cmd == "macode":
        cmd_macode(sys.argv[2:])
    elif cmd == "mawx":
        cmd_mawx(sys.argv[2:])
    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
