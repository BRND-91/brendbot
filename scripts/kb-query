#!/usr/bin/env python3
"""Query the FUSED-CORE knowledge base (SQLite).

Usage:
    kb-query search <terms>          Full-text search across all modules
    kb-query defs <MODULE>           List all definitions in a module
    kb-query facts <MODULE> [topic]  List facts (optionally filtered by topic)
    kb-query thms <MODULE>           List core theorems in a module
    kb-query thms <MODULE> --extended List all theorems including extended (geometry, etc.)
    kb-query def <ID>                Look up a specific definition by ID
    kb-query gates                   List all governance gates
    kb-query xlinks <MODULE>         List crosslinks for a module
    kb-query topics <MODULE>         List available fact topics in a module
    kb-query imagegen <section>      Get IMAGEGEN config section (use 'all' for all, 'sections' to list)
    kb-query memory <source> [tag]   Get memory fragment entries by source file (e.g., bots, tools)
    kb-query memory search <terms>   Search memory fragment content

    Image generation prompt construction:
    kb-query imgstyle <id|label>     Get descriptor set for a named style (e.g. 'junji_ito', 'manga')
    kb-query imgstyle list           List all available styles
    kb-query imgfail <failure_class> Get remediation for a known failure pattern
    kb-query imgfail list            List all known failure classes
    kb-query imglog <request_hash>   Get prior render attempt history for a request hash
    kb-query imglog recent [N]       Get N most recent render outcomes (default 10)

Examples:
    kb-query search "R-value"
    kb-query search "insul*"           (prefix matching)
    kb-query defs BUILDSCI
    kb-query facts BUILDSCI airflow
    kb-query def BSCI.ENCL.RVALUE
    kb-query gates
    kb-query imgstyle junji_ito
    kb-query imgstyle list
    kb-query imgfail style_not_transferred
    kb-query imgfail list
    kb-query imglog recent 5
"""

import sqlite3
import sys
from pathlib import Path

DB_PATH = Path(__file__).resolve().parent.parent / "brendbot" / "knowledge" / "knowledge.db"


def get_conn():
    if not DB_PATH.exists():
        print(f"Error: {DB_PATH} not found. Run migrate_to_sqlite.py first.", file=sys.stderr)
        sys.exit(1)
    return sqlite3.connect(str(DB_PATH))


_SRC_MAP_CACHE = None

def _load_src_maps(conn):
    """Load all src_map entries from modules table to identify unresolved sources."""
    global _SRC_MAP_CACHE
    if _SRC_MAP_CACHE is not None:
        return _SRC_MAP_CACHE
    _SRC_MAP_CACHE = {}
    rows = conn.execute("SELECT id, source_map FROM modules").fetchall()
    for mod_id, sm_json in rows:
        if sm_json:
            try:
                import json
                sm = json.loads(sm_json)
                _SRC_MAP_CACHE.update(sm)
            except (json.JSONDecodeError, TypeError):
                pass
    return _SRC_MAP_CACHE


def _provenance_tag(source, conn=None):
    if not source:
        return "[T2]"
    unresolved_markers = ("unresolved", "flagged T2", "TO_SET")
    if any(m in source for m in unresolved_markers):
        return "[T2]"
    if conn is not None:
        src_maps = _load_src_maps(conn)
        desc = src_maps.get(source, "")
        if any(m in desc for m in unresolved_markers):
            return "[T2]"
    return "[T1]"


def _check_module_coverage(conn, terms):
    modules = conn.execute("SELECT id, description FROM modules").fetchall()
    terms_lower = terms.lower()
    for mod_id, desc in modules:
        if mod_id.lower() in terms_lower or (desc and any(w in terms_lower for w in desc.lower().split() if len(w) > 4)):
            return mod_id
    return None


def cmd_search(terms):
    conn = get_conn()
    fts_terms = '"' + terms.replace('"', '""') + '"'
    results = conn.execute(
        "SELECT module_id, entry_type, term, description, source "
        "FROM fts_knowledge WHERE fts_knowledge MATCH ? LIMIT 20",
        (fts_terms,)
    ).fetchall()

    if not results:
        like = f"%{terms}%"
        results = conn.execute(
            "SELECT module_id, 'def' as entry_type, term, description, source "
            "FROM definitions WHERE term LIKE ? OR description LIKE ? OR formal LIKE ? "
            "UNION ALL "
            "SELECT module_id, 'fact', name, description, source "
            "FROM facts WHERE name LIKE ? OR description LIKE ? "
            "LIMIT 20",
            (like, like, like, like, like)
        ).fetchall()

    if not results:
        matched_module = _check_module_coverage(conn, terms)
        if matched_module:
            print(f"[NO_MODULE_MATCH] Module {matched_module} covers this domain but returned no results.")
            print(f"All outputs for this query are T2+ by default.")
        else:
            print("No results.")
        return

    for mod, etype, term, desc, src in results:
        tier = _provenance_tag(src, conn)
        src_tag = f"|{src}" if src else ""
        print(f"{tier} {mod}.{etype}:{term}={desc}{src_tag}")


def cmd_defs(module):
    conn = get_conn()
    rows = conn.execute(
        "SELECT id, term, description, formal, source FROM definitions WHERE module_id=? ORDER BY id",
        (module.upper(),)
    ).fetchall()
    if not rows:
        print(f"No defs for {module}")
        return
    for did, term, desc, formal, src in rows:
        tier = _provenance_tag(src, conn)
        line = f"{tier} {did}:{term}={desc}" if desc else f"{tier} {did}:{term}"
        if formal:
            line += f"|F:{formal}"
        if src:
            line += f"|{src}"
        print(line)


def cmd_facts(module, topic=None):
    conn = get_conn()
    if topic:
        rows = conn.execute(
            "SELECT topic, name, description, source FROM facts WHERE module_id=? AND topic=? ORDER BY name",
            (module.upper(), topic)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT topic, name, description, source FROM facts WHERE module_id=? ORDER BY topic, name",
            (module.upper(),)
        ).fetchall()
    if not rows:
        print(f"No facts for {module}" + (f"/{topic}" if topic else ""))
        return
    for t, name, desc, src in rows:
        tier = _provenance_tag(src, conn)
        src_tag = f"|{src}" if src else ""
        print(f"{tier} {t}.{name}={desc}{src_tag}")


def cmd_thms(module, include_extended=False):
    conn = get_conn()
    if include_extended:
        rows = conn.execute(
            "SELECT id, description, formal, source, extended FROM theorems WHERE module_id=? ORDER BY extended, id",
            (module.upper(),)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT id, description, formal, source, extended FROM theorems WHERE module_id=? AND extended=0 ORDER BY id",
            (module.upper(),)
        ).fetchall()
    if not rows:
        ext_count = conn.execute(
            "SELECT COUNT(*) FROM theorems WHERE module_id=? AND extended=1",
            (module.upper(),)
        ).fetchone()[0]
        if ext_count and not include_extended:
            print(f"No core thms for {module}. {ext_count} extended theorems available (use --extended).")
        else:
            print(f"No thms for {module}")
        return
    for tid, desc, formal, src, ext in rows:
        tier = _provenance_tag(src, conn)
        line = f"{tier} {tid}={desc}" if desc else f"{tier} {tid}"
        if formal:
            line += f"|F:{formal}"
        if src:
            line += f"|{src}"
        if ext:
            line += " [EXTENDED]"
        print(line)


def cmd_def_lookup(def_id):
    conn = get_conn()
    row = conn.execute(
        "SELECT id, module_id, term, description, formal, source FROM definitions WHERE id=?",
        (def_id,)
    ).fetchone()
    if not row:
        print(f"Definition '{def_id}' not found")
        return
    did, mod, term, desc, formal, src = row
    print(f"Module: {mod}")
    print(f"Term: {term}")
    if desc: print(f"Description: {desc}")
    if formal: print(f"Formal: {formal}")
    if src: print(f"Source: {src}")


def cmd_gates():
    conn = get_conn()
    for gid, rule, fail, note in conn.execute("SELECT * FROM governance_gates ORDER BY id"):
        line = f"{gid}:{rule}|fail={fail}"
        if note:
            line += f"|{note}"
        print(line)


def cmd_xlinks(module):
    conn = get_conn()
    rows = conn.execute(
        "SELECT from_id, to_ids, link_type, note FROM crosslinks WHERE module_id=? ORDER BY from_id",
        (module.upper(),)
    ).fetchall()
    if not rows:
        print(f"No crosslinks found for {module}")
        return
    for fr, to, lt, note in rows:
        print(f"{fr} --[{lt}]--> {to}: {note}")


def cmd_imagegen(section):
    conn = get_conn()
    if section == "sections":
        rows = conn.execute("SELECT section FROM imagegen_config ORDER BY section").fetchall()
        if not rows:
            print("No imagegen_config sections found. Run migrate_to_sqlite.py first.")
            return
        for (s,) in rows:
            print(s)
        return
    if section == "all":
        rows = conn.execute("SELECT section, data FROM imagegen_config ORDER BY section").fetchall()
        if not rows:
            print("No imagegen_config data found. Run migrate_to_sqlite.py first.")
            return
        import json
        for s, d in rows:
            print(f"=== {s} ===")
            print(d)
        return
    row = conn.execute("SELECT data FROM imagegen_config WHERE section=?", (section,)).fetchone()
    if not row:
        print(f"Section '{section}' not found. Use 'kb-query imagegen sections' to list available sections.")
        return
    print(row[0])


def cmd_imgstyle(arg):
    """Look up descriptor set for a named style, or list all styles."""
    conn = get_conn()

    if arg == "list":
        rows = conn.execute(
            "SELECT id, label, model_tier, notes FROM prompt_styles ORDER BY id"
        ).fetchall()
        if not rows:
            print("No prompt_styles found. Run migrate_to_sqlite.py first.")
            return
        for sid, label, tier, notes in rows:
            note_str = f" | {notes}" if notes else ""
            print(f"{sid}: {label} [{tier}]{note_str}")
        return

    # Try exact id match first, then FTS label search
    row = conn.execute(
        "SELECT id, label, core_descriptors, supplemental_descriptors, negative_space, fail_modes, model_tier, notes "
        "FROM prompt_styles WHERE id=?",
        (arg.lower(),)
    ).fetchone()

    if not row:
        # FTS search on label and descriptors
        fts_term = '"' + arg.replace('"', '""') + '"'
        try:
            fts_rows = conn.execute(
                "SELECT id FROM fts_prompts WHERE fts_prompts MATCH ? LIMIT 3",
                (fts_term,)
            ).fetchall()
        except Exception:
            fts_rows = []
        if fts_rows:
            matched_id = fts_rows[0][0]
            row = conn.execute(
                "SELECT id, label, core_descriptors, supplemental_descriptors, negative_space, fail_modes, model_tier, notes "
                "FROM prompt_styles WHERE id=?",
                (matched_id,)
            ).fetchone()

    if not row:
        print(f"Style '{arg}' not found. Use 'kb-query imgstyle list' to see available styles.")
        return

    sid, label, core, supplemental, negative, fail_modes_json, tier, notes = row
    print(f"id: {sid}")
    print(f"label: {label}")
    print(f"tier: {tier}")
    print(f"core: {core}")
    if supplemental:
        print(f"supplemental: {supplemental}")
    if negative:
        print(f"avoid: {negative}")
    if notes:
        print(f"notes: {notes}")


def cmd_imgfail(arg):
    """Look up remediation for a known failure class, or list all classes."""
    conn = get_conn()

    if arg == "list":
        rows = conn.execute(
            "SELECT failure_class, trigger_pattern FROM render_failures ORDER BY failure_class"
        ).fetchall()
        if not rows:
            print("No render_failures found. Run migrate_to_sqlite.py first.")
            return
        for fc, trigger in rows:
            print(f"{fc}: {trigger}")
        return

    row = conn.execute(
        "SELECT failure_class, trigger_pattern, remediation, example "
        "FROM render_failures WHERE failure_class=?",
        (arg,)
    ).fetchone()
    if not row:
        # Try LIKE match
        like = f"%{arg}%"
        rows = conn.execute(
            "SELECT failure_class, trigger_pattern, remediation, example "
            "FROM render_failures WHERE failure_class LIKE ? OR trigger_pattern LIKE ?",
            (like, like)
        ).fetchall()
        if not rows:
            print(f"Failure class '{arg}' not found. Use 'kb-query imgfail list' to see all classes.")
            return
        row = rows[0]

    fc, trigger, remediation, example = row
    print(f"class: {fc}")
    print(f"trigger: {trigger}")
    print(f"remediation: {remediation}")
    if example:
        print(f"example: {example}")


def cmd_imglog(args):
    """Query render outcome history."""
    conn = get_conn()

    if not args:
        print("Usage: kb-query imglog <request_hash> | kb-query imglog recent [N]")
        return

    if args[0] == "recent":
        n = int(args[1]) if len(args) >= 2 else 10
        rows = conn.execute(
            "SELECT request_hash, attempt_number, constraint_score, succeeded, failure_class, notes, created_at "
            "FROM render_outcomes ORDER BY created_at DESC LIMIT ?",
            (n,)
        ).fetchall()
        if not rows:
            print("No render outcomes logged yet.")
            return
        for req_hash, attempt, score, succeeded, fc, notes, ts in rows:
            status = "OK" if succeeded else f"FAIL:{fc or '?'}"
            hash_short = (req_hash or "?")[:12]
            note_str = f" | {notes}" if notes else ""
            print(f"{ts} [{hash_short}] attempt={attempt} constraints={score} {status}{note_str}")
        return

    # Lookup by request hash
    request_hash = args[0]
    rows = conn.execute(
        "SELECT attempt_number, prompt_used, style_ids, constraint_score, succeeded, failure_class, notes, created_at "
        "FROM render_outcomes WHERE request_hash=? ORDER BY attempt_number",
        (request_hash,)
    ).fetchall()
    if not rows:
        print(f"No outcomes found for hash '{request_hash}'.")
        return
    for attempt, prompt, style_ids, score, succeeded, fc, notes, ts in rows:
        status = "OK" if succeeded else f"FAIL:{fc or '?'}"
        print(f"attempt {attempt} [{ts}]: {status} | constraints={score} | styles={style_ids or 'none'}")
        if prompt:
            print(f"  prompt: {prompt[:200]}")
        if notes:
            print(f"  notes: {notes}")


def cmd_memory(args):
    conn = get_conn()
    if args and args[0] == "search":
        terms = " ".join(args[1:])
        like = f"%{terms}%"
        rows = conn.execute(
            "SELECT source, tag, content FROM memory_fragments "
            "WHERE content LIKE ? OR tag LIKE ? ORDER BY source, id",
            (like, like),
        ).fetchall()
        if not rows:
            print("No memory fragment entries matched.")
            return
        for source, tag, content in rows:
            print(f"[{source}/{tag}] {content}")
        return

    if not args:
        rows = conn.execute(
            "SELECT DISTINCT source, COUNT(*) FROM memory_fragments GROUP BY source ORDER BY source"
        ).fetchall()
        if not rows:
            print("memory_fragments table is empty. Run migrate_to_sqlite.py first.")
            return
        for source, count in rows:
            print(f"  {source} ({count} entries)")
        return

    source = args[0]
    tag = args[1] if len(args) >= 2 else None

    if tag:
        rows = conn.execute(
            "SELECT tag, content FROM memory_fragments WHERE source=? AND tag=? ORDER BY id",
            (source, tag),
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT tag, content FROM memory_fragments WHERE source=? ORDER BY id",
            (source,),
        ).fetchall()

    if not rows:
        available = [
            r[0]
            for r in conn.execute(
                "SELECT DISTINCT source FROM memory_fragments ORDER BY source"
            ).fetchall()
        ]
        msg = f"No entries found for source='{source}'"
        if tag:
            msg += f" tag='{tag}'"
        print(msg)
        if available:
            print(f"Available sources: {', '.join(available)}")
        return

    for t, content in rows:
        print(f"[{t}] {content}")


def cmd_topics(module):
    conn = get_conn()
    rows = conn.execute(
        "SELECT DISTINCT topic, COUNT(*) FROM facts WHERE module_id=? GROUP BY topic ORDER BY topic",
        (module.upper(),)
    ).fetchall()
    if not rows:
        print(f"No topics found for {module}")
        return
    for topic, count in rows:
        print(f"  {topic} ({count} facts)")


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "search" and len(sys.argv) >= 3:
        cmd_search(" ".join(sys.argv[2:]))
    elif cmd == "defs" and len(sys.argv) >= 3:
        cmd_defs(sys.argv[2])
    elif cmd == "facts" and len(sys.argv) >= 3:
        topic = sys.argv[3] if len(sys.argv) >= 4 else None
        cmd_facts(sys.argv[2], topic)
    elif cmd == "thms" and len(sys.argv) >= 3:
        extended = "--extended" in sys.argv
        cmd_thms(sys.argv[2], include_extended=extended)
    elif cmd == "def" and len(sys.argv) >= 3:
        cmd_def_lookup(sys.argv[2])
    elif cmd == "gates":
        cmd_gates()
    elif cmd == "xlinks" and len(sys.argv) >= 3:
        cmd_xlinks(sys.argv[2])
    elif cmd == "topics" and len(sys.argv) >= 3:
        cmd_topics(sys.argv[2])
    elif cmd == "imagegen" and len(sys.argv) >= 3:
        cmd_imagegen(sys.argv[2])
    elif cmd == "imgstyle" and len(sys.argv) >= 3:
        cmd_imgstyle(sys.argv[2])
    elif cmd == "imgfail" and len(sys.argv) >= 3:
        cmd_imgfail(sys.argv[2])
    elif cmd == "imglog":
        cmd_imglog(sys.argv[2:])
    elif cmd == "memory":
        cmd_memory(sys.argv[2:])
    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
